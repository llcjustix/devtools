# ===== IMAGE VERSIONS =====
POSTGRES_VERSION=16.13
KEYCLOAK_VERSION=26.1
REDIS_VERSION=7.4.8
REDIS_INSIGHT_VERSION=2.70
MINIO_VERSION=RELEASE.2025-09-07T16-13-09Z
KAFKA_VERSION=7.7.1
KAFKA_UI_VERSION=v0.7.2
JITSI_JICOFO_VERSION=stable-9955
JITSI_JVB_VERSION=stable-9955
JITSI_PROSODY_VERSION=stable-9955
JITSI_WEB_VERSION=stable-9955
JITSI_JIBRI_VERSION=stable-9955

# PostgreSQL variables/
POSTGRES_DB=academy
POSTGRES_USER=postgres
POSTGRES_PASSWORD=passwd

# Keycloak admin (bootstrap)
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=admin

# DB for Keycloak (can reuse Postgres values)
KC_DB_USERNAME=${POSTGRES_USER}
KC_DB_PASSWORD=${POSTGRES_PASSWORD}
KC_DB_URL_HOST=postgres
KC_DB_URL_PORT=5432
KC_DB_URL_DATABASE=${POSTGRES_DB}

# SSL mode:
KC_DB_SSLMODE=disable

# MinIO variables
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123

# Redis variables
REDIS_PASSWORD=passwd

# ===== JITSI CONFIGURATION =====

# JWT Authentication (for backend-controlled access)
JWT_APP_SECRET=4bedb3c00a23fc94f52c1ce939f48f51

# Jitsi Component Secrets
JICOFO_COMPONENT_SECRET=s8e3148709b86095ec1d997ec0b43c7e4e9c058db2d3811e847b6685c7bfd9fcbb60c1f7ca181b18bea6368dfdc1da7b23b5f92c81c
JICOFO_AUTH_PASSWORD=4bedb3c00a23fc94f52c1ce939f48f51
JVB_AUTH_PASSWORD=3b311ec5f8e7a018d6324dab08ac208c

# Jibri (recording) credentials
JIBRI_RECORDER_PASSWORD=a61409d83f64be39a41c3fec09fc2e80
JIBRI_XMPP_PASSWORD=d29d01b28d176cec408b11bb993c6820

# ===== JITSI SERVICE URLs =====
# Docker-internal URLs (Prosody, Lua scripts, Jibri — inside Docker network)
MEETING_SERVICE_URL=http://host.docker.internal:2022/meeting-service
AUTH_SERVICE_URL=http://host.docker.internal:2022/auth-service

# Browser-facing URLs (injected into HTML pages at build time — must be reachable from user's browser)
BROWSER_MEETING_SERVICE_URL=http://localhost:2022/meeting-service
BROWSER_AUTH_SERVICE_URL=http://localhost:2022/auth-service
JITSI_WEBHOOK_SECRET=webhook-secret-change-in-production

# Recording upload (Jibri finalize script → file-service via gateway)
JITSI_RECORDING_FILE_SERVICE_URL=http://host.docker.internal:2022/file-service
JITSI_RECORDING_BUCKET=recordings

# Whiteboard (Excalidraw) - public URL for browser WebSocket connection
WHITEBOARD_COLLAB_SERVER_PUBLIC_URL=http://localhost:8001/whiteboard

# HTTPS toggle (set to 0 in production to enable HTTPS)
DISABLE_HTTPS=1

# Network configuration
PUBLIC_URL=localhost:8001
DOCKER_HOST_ADDRESS=127.0.0.1
